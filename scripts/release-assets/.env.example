# Image bundle runtime
WEBCLIENT_VERSION=__WEBCLIENT_VERSION__
HOST_PORT=11948
# DESKTOP_APP=true

# Backend API base URLs reachable from the deployment target
BASE_URL=http://host.docker.internal:11949
# Optional voice HTTP / WebSocket upstream. Leave empty to hide voice features.
# VOICE_BASE_URL=http://host.docker.internal:11953

# Optional frontend entrypoints. Hidden unless explicitly set to true.
# DEBUG_PANEL_ENABLED=true
# DELTA_LOGS_ENABLED=true
# SETTINGS_MENU_ENABLED=true
# QUICK_ACTIONS_ENABLED=true
