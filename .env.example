# Local development defaults
# PORT is used by webpack dev server locally and by docker compose as the
# exposed host port for container deployment.
PORT=11948
# DESKTOP_APP=true

# Upstream API origins reachable from the current runtime.
# In local development, webpack dev server proxies /api/* and /api/voice/*
# requests to these upstreams.
BASE_URL=http://localhost:11949
WS_BASE_URL=http://localhost:11949
VOICE_BASE_URL=http://localhost:11953

# Optional frontend entrypoints. Hidden unless explicitly set to true.
# DEBUG_PANEL_ENABLED=true
# SETTINGS_MENU_ENABLED=true

# Frontend ASR client gate defaults
# These values control browser-side filtering before audio is sent as asr.audio.append.
# Higher RMS threshold filters more light voice / background noise.
# VOICE_ASR_CLIENT_GATE_ENABLED=true
# VOICE_ASR_CLIENT_GATE_RMS_THRESHOLD=0.015
# VOICE_ASR_CLIENT_GATE_OPEN_HOLD_MS=120
# VOICE_ASR_CLIENT_GATE_CLOSE_HOLD_MS=480
# VOICE_ASR_CLIENT_GATE_PRE_ROLL_MS=240
