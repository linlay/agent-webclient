{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": [
      "ES2020"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "sourceMap": true,
    "outDir": "./dist-electron",
    "rootDir": "./electron",
    "types": [
      "node"
    ]
  },
  "include": [
    "electron/**/*.ts"
  ],
  "exclude": [
    "electron/**/*.test.ts",
    "dist",
    "dist-electron",
    "node_modules"
  ]
}
